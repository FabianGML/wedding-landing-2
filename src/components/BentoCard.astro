---
interface Props {
  span: string;
  index: number;
}

const { span, index } = Astro.props;
---

<div class={`group relative overflow-hidden rounded-sm border border-secondary/30 ${span}`}>
  <a class="glightbox block w-full h-full" href={`/images/gallery/image-${index}-bento.webp`} data-gallery="gallery">
    <img
      src={`/images/gallery/image-${index}-bento.webp`}
      alt={`Claudia & Alberto ${index}`}
      class="w-full h-full object-cover transition-transform duration-500 cursor-pointer group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/25 transition-colors duration-500 pointer-events-none"></div>
  </a>
</div>
