---
import SectionContainer from "@/components/SectionContainer.astro";
import Image from "astro/components/Image.astro";
import dressCodeImg from "@/assets/images/dressCode.webp";
---

<section id="dress-code">
    <SectionContainer>
        <div class="flex justify-center py-16">
            <div class="max-w-lg w-full text-center space-y-8">
                <div class="space-y-3">
                    <h2 class="font-extrabold tracking-widest text-4xl text-secondary" style="font-family: var(--main-font);">Código de vestimenta</h2>
                    <span class="text-2xl">
                        Cóctel
                    </span>
                </div>

                <div class="relative mx-auto w-48 h-64 lg:size-72">
                    <div class="absolute inset-0 rounded-2xl overflow-hidden">
                        <Image
                            src={dressCodeImg}
                            alt="Dress Code Cóctel"
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>

                <div class="space-y-4">
                    <p class="opacity-60 text-sm leading-relaxed max-w-sm mx-auto">
                        Nos encantaría verte lucir tu mejor estilo. Te invitamos a vestir
                        de manera semi formal, piensa en elegancia cómoda para disfrutar
                        la noche junto a nosotros.
                    </p>

                    <hr class="border-t border-current opacity-10" />

                    <div class="space-y-2">
                        <p class="text-xs tracking-wider opacity-40 uppercase">Sugerencias</p>
                        <div class="flex justify-center gap-8 text-sm opacity-60">
                            <div class="space-y-1">
                                <p class="font-bold">Ellas</p>
                                <p class="text-xs leading-relaxed">Vestido corto o midi<br/>Tacones o sandalias</p>
                            </div>
                            <div class="w-0.5 bg-current rounded-full"></div>
                            <div class="space-y-1">
                                <p class="font-bold">Ellos</p>
                                <p class="text-xs leading-relaxed">Traje o pantalón de vestir<br/>Camisa y zapatos formales</p>
                            </div>
                        </div>
                    </div>

                    <hr class="border-t border-current opacity-10" />

                    <p class="text-xs italic opacity-40">
                        Evita el color blanco, por favor. Ese es nuestro privilegio.
                    </p>
                </div>
            </div>
        </div>
    </SectionContainer>
</section>
