---
import Image from "astro/components/Image.astro";
import hero1 from "@/assets/images/hero/hero1.webp";
import hero2 from "@/assets/images/hero/hero2.webp";
import hero3 from "@/assets/images/hero/hero3.webp";
import Timer from "@/components/Timer.astro";

const heroImages = [hero1, hero2, hero3];
---
<section id="home" class="h-lvh max-w-vw flex flex-col items-center justify-center px-8 gap-16">
    <div class="flex w-full justify-between lg:justify-center lg:gap-24">
        <div class="flex flex-col w-6/7 max-w-48 lg:max-w-72 lg:justify-center">
            <h1 class="text-4xl leading-[0.8] lg:text-9xl"><span class="text-[8.5rem] leading-[0.8] lg:text-[13rem]">C</span> &</h1>
            <h1 class="text-[8.5rem] leading-[0.8] text-right lg:text-[13rem]">A</h1>
        </div>
        <div class="flex flex-col gap-4">
            {heroImages.map((image, index) => (
                <Image 
                    src={image} 
                    alt={`Clau & Arturo ${index + 1}`} 
                    class='w-36 h-32 object-cover border-2 grayscale lg:h-48 lg:w-52'
                />
            ))}
        </div>
    </div>
    <div class="border-l-3 pl-2 w-full h-24 lg:max-w-xl flex justify-between relative">
        <div>
            <span class="font-extrabold tracking-widest lg:text-lg">Celebra con nosotros</span>
            <h1 class="names tracking-wider lg:text-lg">Claudia & Alberto</h2>
            <span class="font-extrabold tracking-widest lg:text-lg block mt-3">24.10.2026</span>
        </div>
        <Timer />
    </div>
</section>

<style>
    .names {
        font-family: var(--main-font);
        font-weight: bolder;
    }
</style>